# Convex deployment URL — populated automatically by `pnpm convex:dev` on first run.
VITE_CONVEX_URL=

# Used by `pnpm seed:champions` locally and by GitHub Actions to deploy `main`
# to the long-lived Convex preview deployment named "main".
# Generate a `preview:`-prefixed key from the Convex Dashboard.
CONVEX_DEPLOY_KEY=
